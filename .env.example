# ─── Frontend Environment Variables ────────────────────────────────────────────
# Copy this file to .env.local — it is already gitignored.
#
# Firebase Web SDK config — these values are NOT secret; they are embedded in the
# public JS bundle and secured entirely by Firestore Security Rules.
# Find them in: Firebase Console → Project Settings → Your Apps → SDK setup

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=carbonemissionanalysis.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=carbonemissionanalysis
VITE_FIREBASE_STORAGE_BUCKET=carbonemissionanalysis.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=730536626392
VITE_FIREBASE_APP_ID=1:730536626392:web:046cc4cf6b028a22efefad
VITE_FIREBASE_MEASUREMENT_ID=G-399Q82YSN7

# Backend API base URL
# Production:
VITE_API_URL=https://cutcarbon.onrender.com
# Local development (override in .env.local):
# VITE_API_URL=http://127.0.0.1:8000
