# ─── Backend Environment Variables ─────────────────────────────────────────────
# Copy this file to backend/.env — it is already gitignored.
# NEVER commit backend/.env or serviceAccountKey.json to version control.

# Google Gemini API key — this IS a real secret, replace with your own key.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_REAL_GEMINI_API_KEY_HERE

# Firebase service account key path (relative to backend/)
# The file itself must never be committed — it is gitignored at backend/serviceAccountKey.json
# On Render: upload the JSON content as a secret file and set this env var to its path.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
